<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Cours</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f5f5f5;
    }

    header {
      background: #111;
      color: white;
      padding: 15px;
      text-align: center;
      font-size: 20px;
    }

    .container {
      display: flex;
      height: calc(100vh - 60px);
    }

    .sidebar {
      width: 30%;
      background: white;
      padding: 20px;
      overflow-y: auto;
      border-right: 1px solid #ddd;
    }

    .viewer {
      width: 70%;
      padding: 10px;
    }

    #document-list {
      list-style: none;
      padding: 0;
    }

    #document-list li {
      padding: 10px;
      border-bottom: 1px solid #eee;
      cursor: pointer;
      transition: background 0.2s;
    }

    #document-list li:hover {
      background: #f0f0f0;
    }

    iframe {
      width: 100%;
      height: 100%;
      border: none;
      background: white;
    }

    .upload-box {
      margin-bottom: 20px;
      padding: 10px;
      border: 1px solid #ddd;
      background: #fafafa;
    }

    .upload-box h3 {
      margin-top: 0;
    }

    button {
      margin-top: 5px;
      padding: 5px 10px;
      cursor: pointer;
    }
  </style>
</head>

<body>

<header>
  📚 Dashboard Cours
</header>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">

    <!-- UPLOAD -->
    <div class="upload-box">
      <h3>📤 Upload LaTeX (.zip)</h3>

      <form action="/upload" method="post" enctype="multipart/form-data">
        <input type="file" name="zipfile" accept=".zip" required>
        <br>
        <button type="submit">Uploader</button>
      </form>
    </div>

    <!-- LISTE DOCS -->
    <h3>📄 Mes documents</h3>
    <ul id="document-list"></ul>

  </div>

  <!-- PDF VIEWER -->
  <div class="viewer">
    <iframe id="pdf-viewer"></iframe>
  </div>

</div>

<!-- JS -->
<script src="/js/app.js"></script>

</body>
</html>