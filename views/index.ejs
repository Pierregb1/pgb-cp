
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Accueil</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="header">
    <h1>Plateforme de cours</h1>
    <a href="/login" class="btn">Connexion</a>
  </header>

  <section class="container">
    <h2>À découvrir cette semaine</h2>
    <div id="weekly-math" class="grid"></div>
    <div id="weekly-problem" class="card"></div>
  </section>

  <script>
    async function loadWeekly(){
      const res = await fetch('/api/weekly');
      const data = await res.json();
      const m = data.man || {};
      const w = data.woman || {};
      const p = data.problem || {};
      document.getElementById('weekly-math').innerHTML = `
        <div class="card">
          <h3>Mathématicien</h3>
          <h4>${m.name||''}</h4>
          <p><em>${m.era||''}</em></p>
          <p>${m.summary||''}</p>
        </div>
        <div class="card">
          <h3>Mathématicienne</h3>
          <h4>${w.name||''}</h4>
          <p><em>${w.era||''}</em></p>
          <p>${w.summary||''}</p>
        </div>`;
      document.getElementById('weekly-problem').innerHTML = `
        <h3>Problème de la semaine</h3>
        <h4>${p.title||''}</h4>
        <p>${p.statement||''}</p>
        <details><summary>Indice</summary><p>${p.hint||''}</p></details>
        <details><summary>Solution</summary><p>${p.solution||''}</p></details>
      `;
    }
    loadWeekly();
  </script>
</body>
</html>
